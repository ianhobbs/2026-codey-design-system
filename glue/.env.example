# ─────────────────────────────────────────────────────────────────────
#  glue/ — project env & secrets, kept OUTSIDE the web root.
#
#  Copy this to glue/.env and fill in. Everything in glue/ is gitignored
#  except this .example and .gitkeep, so real secrets never land in git.
#
#  Optional split (deploy.sh handles all three):
#    glue/.env             shared across environments (pushed)
#    glue/.env.production  server-only values         (pushed)
#    glue/.env.local       dev-only values            (NEVER pushed)
#
#  Read in Kirby via env('KEY') (johannschopplich/kirby-helpers).
# ─────────────────────────────────────────────────────────────────────

KIRBY_DEBUG=false
API_SECRET_KEY=
DATABASE_URL=
MAIL_FROM=you@example.com

# ── Payments (optional — bnomei stripe / kirby-klub) ────────────────
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET is per-environment — set it in
# glue/.env.production (server) and glue/.env.local (dev), not here.
# KLUB_LICENSE_KEY=            # if you add bnomei/kirby-klub

# ── Integrations (optional) ─────────────────────────────────────────
PAGESPEED_API_KEY=
CLOUDFLARE_API_TOKEN=
