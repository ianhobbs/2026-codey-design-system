# ── The zone boundary that makes clobbering impossible ──
# Synced (composer-restored) overwrite zones — treated like vendor/, never committed.
src/assets/css/codey/
src/site/plugins/codey/
src/assets/fonts/codey/
src/.codey-version

# Dependencies + compiled output
vendor/
node_modules/
build/

# Everything else under src/ IS project-owned and committed:
#   src/assets/css/main.css, brand.css, templates/*, src/site/{snippets,templates}/*

.DS_Store
