{
  "name": "codey/example-project",
  "description": "Demonstrates consuming the Codey design system via Composer + a post-install sync into src/.",
  "repositories": [
    { "type": "path", "url": "../package", "options": { "symlink": false } }
  ],
  "require": {
    "ianhobbsmedia/codey-design-system": "*"
  },
  "scripts": {
    "codey-sync": "node vendor/ianhobbsmedia/codey-design-system/scripts/codey-sync.js",
    "post-install-cmd": [ "@codey-sync" ],
    "post-update-cmd": [ "@codey-sync" ]
  }
}
