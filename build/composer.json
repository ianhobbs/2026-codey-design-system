{
  "name": "ianhobbsmedia/codey",
  "description": "Codey — a Kirby design-system starter. Clone, composer install, build.",
  "type": "project",
  "license": "proprietary",
  "authors": [
    { "name": "Ian Hobbs", "email": "admin@ianhobbsmedia.com", "homepage": "https://ianhobbsmedia.com" }
  ],
  "homepage": "https://ianhobbsmedia.com",
  "require": {
    "php": "~8.2.0 || ~8.3.0 || ~8.4.0",
    "getkirby/cms": "^5.2",
    "getkirby/cli": "^1.9",
    "bnomei/kirby3-fingerprint": "^5.0",
    "bnomei/kirby-janitor": "^5.4",
    "johannschopplich/kirby-helpers": "^6.5",
    "bnomei/kirby3-monolog": "^5.0",
    "tobimori/kirby-icon-field": "^2.3",
    "tobimori/kirby-seo": "2.0.0-beta.4",
    "medienbaecker/kirby-alter": "^2.1",
    "pechente/kirby-password-guard": "^1.3",
    "beebmx/kirby-email-plus": "^1.2",
    "resend/resend-php": "^1.3",
    "stripe/stripe-php": "^13.18",
    "ianhobbs/kirby-swiper-block": "dev-main"
  },
  "require-dev": {
    "bnomei/kirby-mcp": "^1.8"
  },
  "repositories": [
    { "type": "vcs", "url": "https://github.com/ianhobbs/swiper-block.git" }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "getkirby/composer-installer": true,
      "php-http/discovery": true
    },
    "optimize-autoloader": true
  },
  "scripts": {
    "start": [
      "Composer\\Config::disableProcessTimeout",
      "@php -S localhost:8000 kirby/router.php"
    ]
  }
}
